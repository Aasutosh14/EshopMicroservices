{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "catalog": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        }
      },
      "basket": {
        "ClusterId": "basket",
        "Match": {
          "Path": "/basket/{**catch-all}"
        }
      },
      "ordering": {
        "ClusterId": "ordering",
        "RateLimiterPolicy": "Fixed",
        "Match": {
          "Path": "/ordering/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalog1": {
            "Address": "http://catalog.api-1:8080/"
          }
        }
      },
      "basket": {
        "Destinations": {
          "basket1": {
            "Address": "http://basket.api-1:8080/"
          }
        }
      },
      "ordering": {
        "Destinations": {
          "ordering1": {
            "Address": "http://ordering.api-1:8080/"
          }
        }
      }
    }
  }

}
